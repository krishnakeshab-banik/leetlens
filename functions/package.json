{
  "name": "leetlens-functions",
  "description": "LeetLens Cloud Functions — email reminders via Resend",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "dependencies": {
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^6.3.0",
    "resend": "^4.1.2"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  },
  "private": true
}
