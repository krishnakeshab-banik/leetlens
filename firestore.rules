rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // User profile document (leetcodeUsername, githubUsername, settings, etc.)
    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if false;

      match /stats/{docId} {
        allow read, write: if isOwner(uid);
      }

      match /dailySnapshots/{docId} {
        allow read, write: if isOwner(uid);
      }

      match /solvedProblems/{docId} {
        allow read, write: if isOwner(uid);
      }

      match /activity/{docId} {
        allow read, write: if isOwner(uid);
      }

      match /weeklyPlans/{docId} {
        allow read, write: if isOwner(uid);
      }
    }

    // Squads — all writes via Admin SDK (Vercel API / Cloud Functions)
    match /squads/{squadId} {
      allow read, write: if false;
      match /members/{memberId} {
        allow read, write: if false;
      }
      match /baselines/{baselineId} {
        allow read, write: if false;
      }
      match /leaderboard/{entryId} {
        allow read, write: if false;
      }
      match /results/{resultId} {
        allow read, write: if false;
      }
    }

    match /squadCodes/{code} {
      allow read, write: if false;
    }

    match /userSquads/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;
      match /entries/{entryId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }
    }
  }
}
