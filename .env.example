# Firebase (from Firebase Console → Project settings)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Firebase Console → Authentication → Sign-in method → Google → Web client ID
# (Used by the Chrome extension via chrome.identity.launchWebAuthFlow + Firebase signInWithCredential)
VITE_FIREBASE_GOOGLE_WEB_CLIENT_ID=

# Vercel Squads API — Firebase Admin SDK (required for sign-in token verification)
# Local dev: path to downloaded service account JSON (easiest)
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json
# Vercel production: use ONE of the below (not PATH — the JSON file is not on the server)
# Generate values: node scripts/print-service-account-env.js
# Option A (recommended on Vercel): base64-encoded minified JSON
FIREBASE_SERVICE_ACCOUNT_BASE64=
# Option B: minified JSON on one line (no line breaks in the value)
FIREBASE_SERVICE_ACCOUNT=

# MongoDB — Squads competitions database
# Replace <db_password> with your Atlas password
MONGODB_URI=mongodb+srv://krishnakeshabbanik_db_user:<db_password>@leetlens.1abpn0j.mongodb.net/?appName=Leetlens
MONGODB_DB_NAME=leetlens

# Production (Vercel): set MONGODB_URI + MONGODB_DB_NAME + FIREBASE_SERVICE_ACCOUNT_BASE64 (or FIREBASE_SERVICE_ACCOUNT).
# Optional: canonical public URL for squad invite links (defaults to https://leetlens.srminsider.in)
PUBLIC_SITE_URL=https://leetlens.srminsider.in
# Do NOT set FIREBASE_SERVICE_ACCOUNT_PATH on Vercel — the key file is not deployed.
# Firebase Console → Authentication → Settings → Authorized domains → add leetlens.srminsider.in
# After deploy, verify: GET https://your-domain/api/squads/health → { "ok": true }
