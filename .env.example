# Firebase (from Firebase Console → Project settings)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Firebase Google Web client ID (Firebase Console → Authentication → Sign-in method → Google → Web client ID)
# Required for Chrome extension Google sign-in (chrome.identity.launchWebAuthFlow).
# Also add https://YOUR_EXTENSION_ID.chromiumapp.org/ as an authorized redirect URI on that OAuth client.
VITE_FIREBASE_GOOGLE_WEB_CLIENT_ID=
